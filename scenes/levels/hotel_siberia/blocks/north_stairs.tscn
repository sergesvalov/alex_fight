# =============================================================================
# NorthStairsBlock — П-образная трёхмаршевая лестница
#
# Инстанциируется генератором: inst.position = Vector3(1.05, 0, -30.0)
# Дыра в полу (global): X=[-2.55..+4.65], Z=[-30.0..-25.2]
# Блок (local): X=[-3.7..+3.7], Z=[0.0..4.9]
#
# Задача: поднять игрока Y=0 → Y=4.5 (= corridor_height + floor_thickness)
#
# Три пролёта:
#   EastFlight:  Y=0 → 1.5   (восток, Z=2.4→0)
#   NorthFlight: Y=1.5 → 3.0 (поперечный, X=+1.2→-1.2)
#   WestFlight:  Y=3.0 → 4.5 (запад,   Z=2.4→4.8)
#
# Площадки:
#   NELanding: local X≈+2.4, Z=0..2.4, surface Y=1.5
#   NWLanding: local X≈-2.4, Z=0..2.4, surface Y=3.0
#
# Двери (south wall, local Z=4.9):
#   Вход  (восток): local X=+2.8, Y=0..2.2   (lower entry)
#   Выход (запад):  local X=-2.8, Y=4.5..6.7 (upper exit)
#
# Transform рамп: -90° Y => (-4.37114e-08, 0, -1, 0, 1, 0, 1, 0, -4.37114e-08)
#   polygon.x → world -Z, polygon.y → world +Y, depth → world +X
# =============================================================================

[node name="NorthStairsBlock" type="Node3D"]
script = ExtResource("3_script")

[node name="StairsGeometry" type="CSGCombiner3D" parent="."]
use_collision = true
collision_layer = 2

# --- OUTER WALLS ---

# West wall: X=-3.7, Z=0..5.0, Y=0..7.0
[node name="StairsWestWall" type="CSGBox3D" parent="StairsGeometry"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -3.7, 3.5, 2.5)
size = Vector3(0.2, 7.0, 5.0)
material = SubResource("StandardMaterial3D_wall")

# East wall: X=+3.7, Z=0..5.0, Y=0..7.0
[node name="StairsEastWall" type="CSGBox3D" parent="StairsGeometry"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3.7, 3.5, 2.5)
size = Vector3(0.2, 7.0, 5.0)
material = SubResource("StandardMaterial3D_wall")

# South wall (faces corridor): Z=4.9, Y=0..7.0
# Will have two door holes cut below
[node name="StairsSouthWall" type="CSGBox3D" parent="StairsGeometry"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 3.5, 4.9)
size = Vector3(7.6, 7.0, 0.2)
material = SubResource("StandardMaterial3D_wall")

# East door hole (lower entry): X=+2.8, Y=0..2.2
[node name="StairsDoorHoleEast" type="CSGBox3D" parent="StairsGeometry"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 2.8, 1.11, 4.9)
operation = 2
size = Vector3(1.2, 2.18, 1.0)

# West door hole (upper exit): X=-2.8, Y=4.5..6.7
[node name="StairsDoorHoleWest" type="CSGBox3D" parent="StairsGeometry"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -2.8, 5.61, 4.9)
operation = 2
size = Vector3(1.2, 2.18, 1.0)

# --- LANDINGS ---

# NE Landing: east side, north end. Surface Y=1.5.
# Center: X=+2.4, Y=1.4, Z=1.2  => top surface at Y=1.5
[node name="NELanding" type="CSGBox3D" parent="StairsGeometry"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 2.4, 1.4, 1.2)
size = Vector3(2.4, 0.2, 2.4)
material = SubResource("StandardMaterial3D_floor")

# NW Landing: west side, north end. Surface Y=3.0.
# Center: X=-2.4, Y=2.9, Z=1.2 => top surface at Y=3.0
[node name="NWLanding" type="CSGBox3D" parent="StairsGeometry"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -2.4, 2.9, 1.2)
size = Vector3(2.4, 0.2, 2.4)
material = SubResource("StandardMaterial3D_floor")

# --- RAMP FLIGHTS ---
#
# All three flights use CSGPolygon3D.
# Transform -90°Y: (-4.37114e-08, 0, -1, 0, 1, 0, 1, 0, -4.37114e-08, ox, 0, oz)
#   polygon.x → world -Z  (along corridor axis, south→north)
#   polygon.y → world +Y  (height)
#   depth     → world +X  (width of slab)
#
# EastFlight: восточный пролёт, Z=0→2.4 (local), Y=0→1.5
#   origin (X=2.2, Y=0, Z=2.4), depth=1.2 → X=2.2..3.4
#   polygon.x=0   → Z=2.4, Y=1.5 (NE Landing surface)
#   polygon.x=2.4 → Z=0.0, Y=0.0 (пол у северной стены)

[node name="EastFlight" type="CSGPolygon3D" parent="StairsGeometry"]
transform = Transform3D(-4.37114e-08, 0, -1, 0, 1, 0, 1, 0, -4.37114e-08, 2.2, 0, 2.4)
polygon = PackedVector2Array(0, 1.3, 2.4, -0.2, 2.4, 0, 0, 1.5)
depth = 1.2
material = SubResource("StandardMaterial3D_floor")

# NorthFlight: поперечный пролёт (Z=2.4..4.8), соединяет NE (Y=1.5) и NW (Y=3.0)
#   identity transform: polygon.x → world +X, polygon.y → world +Y, depth → world +Z
#   origin (X=0, Y=0, Z=2.4), depth=2.4 → Z=2.4..4.8
#   polygon.x=+1.2 → world X=+1.2 (восток, Y=1.5)
#   polygon.x=-1.2 → world X=-1.2 (запад, Y=3.0)

[node name="NorthFlight" type="CSGPolygon3D" parent="StairsGeometry"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 2.4)
polygon = PackedVector2Array(1.2, 1.5, -1.2, 3.0, -1.2, 2.8, 1.2, 1.3)
depth = 2.4
material = SubResource("StandardMaterial3D_floor")

# WestFlight: западный пролёт, Z=0→2.4 (local), Y=3.0→4.5
#   origin (X=-3.4, Y=0, Z=2.4), depth=1.2 → X=-3.4..-2.2
#   polygon.x=0   → Z=2.4, Y=3.0 (NW Landing, южный конец пролёта)
#   polygon.x=2.4 → Z=0.0, Y=4.5 (верхняя точка у северной стены)
#   Затем плоский участок Z=0→4.9 на Y=4.5 до выходной двери запада.

[node name="WestFlight" type="CSGPolygon3D" parent="StairsGeometry"]
transform = Transform3D(-4.37114e-08, 0, -1, 0, 1, 0, 1, 0, -4.37114e-08, -3.4, 0, 2.4)
polygon = PackedVector2Array(0, 2.8, 2.4, 4.3, 2.4, 4.5, 0, 3.0)
depth = 1.2
material = SubResource("StandardMaterial3D_floor")

# EastFloor: flat section from Z=0.0 to Z=4.9 at Y=0.0 (ground floor)
[node name="EastFloor" type="CSGBox3D" parent="StairsGeometry"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 2.8, -0.1, 2.45)
size = Vector3(1.2, 0.2, 4.9)
material = SubResource("StandardMaterial3D_floor")

# WestFloor: flat section from Z=0.0 to Z=4.9 at Y=4.5 to west exit door
[node name="WestFloor" type="CSGBox3D" parent="StairsGeometry"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -2.8, 4.4, 2.45)
size = Vector3(1.2, 0.2, 4.9)
material = SubResource("StandardMaterial3D_floor")

